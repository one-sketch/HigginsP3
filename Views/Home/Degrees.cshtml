@model HigginsP3.Models.DegreesModel
@{
    ViewData["Title"] = "Degrees";
}

<div class="page-hero">
    <div class="page-hero-inner">
        <p class="page-eyebrow">Academics</p>
        <h1 class="page-title">Degrees &amp; Programs</h1>
    </div>
</div>

<div class="content-section">
    <div class="content-inner">

        <!-- UNDERGRADUATE -->
        <div class="degrees-section-label">Undergraduate</div>
        <div id="accordion-undergrad" class="degree-accordion">
            @foreach (var d in Model.undergraduate)
            {
                <h3>
                    <span class="acc-degree-name">@d.degreeName</span>
                    <span class="acc-degree-title">@d.title</span>
                </h3>
                <div>
                    <p class="acc-desc">@d.description</p>

                    @if (d.concentrations != null && d.concentrations.Count > 0)
                    {
                        <div class="acc-sub-label">Concentrations</div>
                        <div class="acc-tags">
                            @foreach (var c in d.concentrations)
                            {
                                <span class="tag">@c</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- GRADUATE -->
        <div class="degrees-section-label" style="margin-top: 3rem;">Graduate</div>
        <div id="accordion-grad" class="degree-accordion">
            @foreach (var g in Model.graduate)
            {
                <h3>
                    <span class="acc-degree-name">@g.degreeName</span>
                    <span class="acc-degree-title">@g.title</span>
                </h3>
                <div>
                    <p class="acc-desc">@g.description</p>

                    @if (g.concentrations != null && g.concentrations.Count > 0)
                    {
                        <div class="acc-sub-label">Concentrations</div>
                        <div class="acc-tags">
                            @foreach (var c in g.concentrations)
                            {
                                <span class="tag">@c</span>
                            }
                        </div>
                    }

                    @if (g.availableCertificates != null && g.availableCertificates.Count > 0)
                    {
                        <div class="acc-sub-label" style="margin-top:1rem;">Available Certificates</div>
                        <div class="acc-tags">
                            @foreach (var cert in g.availableCertificates)
                            {
                                <span class="tag tag-outline">@cert</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $("#accordion-undergrad").accordion({
            collapsible: true,
            heightStyle: "content",
            active: false
        });
        $("#accordion-grad").accordion({
            collapsible: true,
            heightStyle: "content",
            active: false
        });
    });
</script>
}
