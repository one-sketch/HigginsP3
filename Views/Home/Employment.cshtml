@model HigginsP3.Models.EmploymentModel


<div class="section-wrapper">
    <div class="section-label">Career Outcomes</div>

    <h1 class="section-title">@Model.introduction.title</h1>

    @foreach (var block in Model.introduction.content)
    {
        <p class="employment-section-text">@block.description</p>
    }
</div>

@if (Model?.degreeStatistics?.statistics != null)
{
    <div class="section-wrapper">
        <div class="section-label">Degree Statistics — At a Glance</div>

        @foreach (var stat in Model.degreeStatistics.statistics)
        {
            <div class="employment-stat">
                <div class="employment-stat-value">@stat.value</div>
                <div class="employment-stat-desc">@stat.description</div>
            </div>
        }
    </div>
}

<div class="table-block">
    <div class="table-block-title">Selected Employers</div>

    <div class="datagrid-wrap">
        <div style="padding: 1.5rem;">
            @if (Model?.employers?.employerNames != null)
            {
                foreach (var emp in Model.employers.employerNames)
                {
                    <div class="employer-item">
                        @emp
                    </div>
                }
            }
        </div>
    </div>
</div>
<div class="table-block">
    <div class="table-block-title">Career Titles</div>

    <div class="datagrid-wrap">
        <div style="padding: 1.5rem;">
            @if (Model?.careers?.careerNames != null)
            {
                foreach (var career in Model.careers.careerNames)
                {
                    <div class="career-item">
                        @career
                    </div>
                }
            }
        </div>
    </div>
</div>
<div class="table-block">
    <div class="table-block-title">Co-op Table</div>
    <div class="datagrid-wrap">
        <table id="coopTable">
            <thead>
                <tr>
                    <th>Employer</th>
                    <th>Degree</th>
                    <th>City</th>
                    <th>Term</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.coopTable.coopInformation)
                {
                    <tr>
                        <td>@item.employer</td>
                        <td>@item.degree</td>
                        <td>@item.city</td>
                        <td>@item.term</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="table-block">
    <div class="table-block-title">Employment Table</div>
    <div class="datagrid-wrap">

<table id="employmentTable">
    <thead>
        <tr>
            <th>Employer</th>
            <th>Degree</th>
            <th>City</th>
            <th>Title</th>
            <th>Start Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model.employmentTable.professionalEmploymentInformation)
        {
            <tr>
                <td>@job.employer</td>
                <td>@job.degree</td>
                <td>@job.city</td>
                <td>@job.title</td>
                <td>@job.startDate</td>
            </tr>
        }
    </tbody>
</table>
    </div>
</div>  
</div>
@section Scripts {
<script>
    $(document).ready(function () {
        $('#coopTable').DataTable({
            pageLength: 5,
            lengthChange: false
        });

        $('#employmentTable').DataTable({
            pageLength: 5,
            lengthChange: false
        });
    });
</script>
}