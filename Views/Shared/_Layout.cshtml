<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - iSchool @@ RIT</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Serif+Display&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />

    <!-- jQuery UI CSS (local) -->
    <link rel="stylesheet" href="~/lib/jquery-ui/jquery-ui.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- NAV -->
    <header class="site-header">
        <nav class="site-nav">
            <a class="site-logo" asp-controller="Home" asp-action="Index">
                <span class="logo-bracket">[</span>i<span class="logo-bracket">]</span>School
            </a>
            <ul class="nav-links">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Home" asp-action="About">About</a></li>
                <li><a asp-controller="Home" asp-action="People">People</a></li>
                <li><a asp-controller="Home" asp-action="Degrees">Degrees</a></li>
                <li><a asp-controller="Home" asp-action="Minors">Minors</a></li>
                <li><a asp-controller="Home" asp-action="Employment">Employment</a></li>
            </ul>
        </nav>
    </header>

    <!-- MAIN -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="footer-inner">
            <span class="footer-logo">
                <span class="logo-bracket">[</span>i<span class="logo-bracket">]</span>School
            </span>
            <span class="footer-copy">&copy; @DateTime.Now.Year Rochester Institute of Technology</span>
        </div>
    </footer>

    <!-- JS: jQuery first -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- jQuery UI -->
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <!-- jQuery Cycle2 (local) -->
    <script src="~/lib/jquery-cycle2/jquery.cycle2.min.js"></script>
    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
